      <MdxScripts>
        <MdxScript>
          <ID>MdxScript</ID>
          <Name>MdxScript</Name>
          <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
          <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
          <Commands>
            <Command>
              <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE;                   
CREATE DYNAMIC SET CURRENTCUBE.[Top 10 Negative Product Profit]
 AS TOPCOUNT( FILTER( [Dim Product].[Product Name].[Product Name].MEMBERS, [Measures].[Profit] &lt; 0 ), 10, ABS([Measures].[Profit]) );     
CREATE DYNAMIC SET CURRENTCUBE.[Top 1 Category Quantity]
 AS TOPCOUNT([Dim Category].[Category].[Category].ALLMEMBERS,1,[Measures].[Quantity]) ;              
CREATE DYNAMIC SET CURRENTCUBE.[Top 10 Customer Profit]
 AS TOPCOUNT([Dim Customer].[Customer Name].CHILDREN, 10,[Measures].[Profit]);                 
CREATE DYNAMIC SET CURRENTCUBE.[Top 5 City Sales]
 AS TOPCOUNT([Dim Location].[City].CHILDREN, 5,[Measures].[Sales]);       
CREATE DYNAMIC SET CURRENTCUBE.[Top 3 Product Sales]
 AS TOPCOUNT([Dim Product].[Product Name].[Product Name].ALLMEMBERS,3,[Measures].[Sales]);                         
CREATE MEMBER CURRENTCUBE.[Measures].[Discount Amount]
 AS SUM(EXISTING [FACT].[Row ID].[Row ID].MEMBERS, 
    [Measures].[Sales] * [Measures].[Discount]), 
VISIBLE = 1;                          
CREATE MEMBER CURRENTCUBE.[Measures].[Avg Discount]
 AS AVG([FACT].[Order ID].[Order ID], [Measures].[Discount]), 
VISIBLE = 1;                         
CREATE MEMBER CURRENTCUBE.[Measures].[Avg DaysToShip]
 AS AVG([FACT].[Row ID].[Row ID], [Measures].[Days To Ship]), 
VISIBLE = 1;                         
CREATE MEMBER CURRENTCUBE.[Measures].[Avg Sales]
 AS AVG([FACT].[Order ID].[Order ID], [Measures].[Sales]), 
VISIBLE = 1;                         
CREATE MEMBER CURRENTCUBE.[Measures].[Avg Quantity]
 AS AVG([FACT].[Order ID].[Order ID], [Measures].[Quantity]), 
VISIBLE = 1;                          
CREATE MEMBER CURRENTCUBE.[Measures].[Avg Profit]
 AS AVG([FACT].[Order ID].[Order ID], [Measures].[Profit]), 
VISIBLE = 1; </Text>
            </Command>
          </Commands>
        </MdxScript>
      </MdxScripts>
    </Cube>
  </Cubes>
